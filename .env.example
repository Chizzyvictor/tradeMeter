# TradeMeter environment configuration example
# Copy this file to your server environment and set real values.
# Do not commit real credentials.

# Database configuration
# SQLite remains default; set SQLITE_DB_PATH only if you need a custom location.
# DATABASE_URL is reserved for the PostgreSQL migration path.
DATABASE_URL=
PGSSLMODE=require
SQLITE_DB_PATH=

# SMTP configuration (optional; app falls back to native mail() when SMTP_HOST is empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_AUTH=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=TradeMeter
EMAIL_VERIFICATION_STRICT=true

# Persistent image storage (optional but recommended for Heroku)
# When set, uploads are stored in Cloudinary instead of local Images/.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=trademeter
