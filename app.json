{
  "name": "TradeMeter",
  "description": "TradeMeter inventory and transactions app (PHP + SQLite)",
  "keywords": ["php", "sqlite", "inventory", "transactions"],
  "website": "https://github.com/Chizzyvictor/tradeMeter",
  "repository": "https://github.com/Chizzyvictor/tradeMeter",
  "env": {
    "SMTP_HOST": {
      "description": "SMTP server host (optional)",
      "required": false
    },
    "SMTP_PORT": {
      "description": "SMTP server port",
      "required": false,
      "value": "587"
    },
    "SMTP_AUTH": {
      "description": "Enable SMTP auth",
      "required": false,
      "value": "true"
    },
    "SMTP_USERNAME": {
      "description": "SMTP username",
      "required": false
    },
    "SMTP_PASSWORD": {
      "description": "SMTP password",
      "required": false
    },
    "SMTP_ENCRYPTION": {
      "description": "SMTP encryption (tls/ssl)",
      "required": false,
      "value": "tls"
    },
    "SMTP_FROM_EMAIL": {
      "description": "Sender email",
      "required": false
    },
    "SMTP_FROM_NAME": {
      "description": "Sender display name",
      "required": false,
      "value": "TradeMeter"
    }
  }
}
